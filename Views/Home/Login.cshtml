@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Login</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f0f4f8;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.12);
            padding: 40px 36px 36px;
            width: 320px;
        }

            .login-card h2 {
                text-align: center;
                font-size: 22px;
                font-weight: 600;
                color: #333;
                margin-bottom: 28px;
            }

        .input-group {
            position: relative;
            margin-bottom: 16px;
        }

            .input-group .icon {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #aaa;
                font-size: 14px;
            }

            .input-group input {
                width: 100%;
                padding: 10px 36px 10px 36px;
                border: 1px solid #ddd;
                border-radius: 5px;
                font-size: 14px;
                color: #333;
                outline: none;
                transition: border-color 0.2s;
            }

                .input-group input:focus {
                    border-color: #337ab7;
                }

                .input-group input::placeholder {
                    color: #bbb;
                }

            .input-group .clear-btn {
                position: absolute;
                right: 10px;
                top: 50%;
                transform: translateY(-50%);
                color: #ccc;
                font-size: 13px;
                cursor: pointer;
                background: none;
                border: none;
                padding: 0;
            }

                .input-group .clear-btn:hover {
                    color: #999;
                }

        .thong-bao {
            font-style: italic;
            color: red;
            font-size: 12px;
            margin-top: -8px;
            margin-bottom: 10px;
            min-height: 16px;
        }

        .btn-login {
            width: 100%;
            padding: 10px;
            background-color: #337ab7;
            color: #fff;
            border: none;
            border-radius: 5px;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            margin-top: 8px;
            transition: background-color 0.2s;
        }

            .btn-login:hover {
                background-color: #286090;
            }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>Login</h2>

        @* Form POST về Admin area - HomeController - action Login *@
        @using (Html.BeginForm("Login", "Home", new { area = "Admin" }, FormMethod.Post))
        {
            @Html.Hidden("url", (string)ViewBag.url)

            <div class="input-group">
                <i class="icon fa fa-user"></i>
                @Html.TextBox("UserName", "", new { placeholder = "Username" })
                <button type="button" class="clear-btn" onclick="this.previousElementSibling.value=''">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            <div class="input-group">
                <i class="icon fa fa-lock"></i>
                @Html.Password("Password", "", new { placeholder = "Password" })
                <button type="button" class="clear-btn" onclick="this.previousElementSibling.value=''">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            @* Hiển thị thông báo lỗi khi sai tài khoản/mật khẩu *@
            <p class="thong-bao">@ViewBag.ThongBao</p>

            <button type="submit" class="btn-login">Login</button>
        }
    </div>
</body>
</html>
