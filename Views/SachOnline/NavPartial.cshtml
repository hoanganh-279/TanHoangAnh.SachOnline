<nav class="navbar navbar-expand-lg navbar-dark bg-dark" style="border-radius: 0;">
    <div class="container">
        @Html.ActionLink("SachOnline", "Index", "SachOnline", new { area = "" }, new { @class = "navbar-brand" })

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainMenu">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "SachOnline")">
                        TRANG CHỦ
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-uppercase" href="#">Giới thiệu</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-uppercase" href="#">Liên hệ</a>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        Sách theo chủ đề
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="@Url.Action("SachTheoChuDe", "SachOnline", new { id = 1 })">Ngoại ngữ</a></li>
                        <li><a class="dropdown-item" href="@Url.Action("SachTheoChuDe", "SachOnline", new { id = 2 })">Công nghệ thông tin</a></li>
                        <li><a class="dropdown-item" href="@Url.Action("SachTheoChuDe", "SachOnline", new { id = 3 })">Văn học</a></li>
                    </ul>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        Sách theo nhà xuất bản
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="@Url.Action("SachTheoNhaXuatBan", "SachOnline", new { id = 1 })">Nhà xuất bản Trẻ</a></li>
                        <li><a class="dropdown-item" href="@Url.Action("SachTheoNhaXuatBan", "SachOnline", new { id = 2 })">NXB Tổng hợp</a></li>
                    </ul>
                </li>
            </ul>

            <form class="d-flex">
                <input class="form-control me-2" type="text" placeholder="Tìm kiếm" aria-label="Search" style="border-radius: 0;">
                <button class="btn btn-light" type="submit" style="border-radius: 0;">Tìm</button>
            </form>

            @* Giỏ hàng *@
            @Html.Action("GioHangPartial", "GioHang")

            <div class="d-flex ms-3 align-items-center">
                @if (Session["TaiKhoan"] != null)
                {
                    var kh = Session["TaiKhoan"] as TanHoangAnh.SachOnline.Models.KHACHHANG;
                    string hoTen = kh != null ? kh.HoTen : "";
                    <div class="dropdown">
                        <a href="#" class="dropdown-toggle d-flex align-items-center text-decoration-none"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="~/Images/img_user.jpg" alt="Avatar"
                                 style="width: 36px; height: 36px; border-radius: 50%; border: 2px solid #fff; object-fit: cover; margin-right: 8px;">
                            <span class="text-white" style="font-weight: bold;">@hoTen</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#">
                                    <span class="glyphicon glyphicon-user" style="margin-right:6px;"></span>
                                    Trang cá nhân
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="@Url.Action("DangXuat", "User")">
                                    <span class="glyphicon glyphicon-log-out" style="margin-right:6px;"></span>
                                    Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <img src="~/Images/img_user.jpg" alt="User"
                         style="width: 32px; height: 32px; border-radius: 50%; border: 2px solid #fff; margin-right: 10px; object-fit: cover;">
                    <a href="@Url.Action("DangNhap", "User")" class="btn btn-outline-light btn-sm me-2" style="border-radius: 5px;">Đăng nhập</a>
                    <a href="@Url.Action("DangKy", "User")" class="btn btn-warning btn-sm" style="border-radius: 5px; font-weight: bold;">Đăng ký</a>
                }
            </div>
        </div>
    </div>
</nav>