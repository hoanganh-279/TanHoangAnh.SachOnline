@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Đăng nhập - SachOnline</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
</head>
<body style="background-color: #f4f6f9;">

    @Html.Action("NavPartial", "SachOnline")

    <div class="container" style="margin-top: 50px;">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-lg border-0 rounded-lg">
                    <div class="card-header bg-primary text-white text-center">
                        <h3 class="font-weight-light my-2">ĐĂNG NHẬP</h3>
                    </div>
                    <div class="card-body" style="padding: 40px;">
                        <h5 class="text-danger text-center">@ViewBag.ThongBao</h5>

                        @using (Html.BeginForm("DangNhap", "User", FormMethod.Post))
                        {
                            <div class="mb-3">
                                <label class="form-label">Tên đăng nhập:</label>
                                @Html.TextBox("TenDN", "", new { @class = "form-control" })
                                <span class="text-danger">@ViewData["Err1"]</span>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Mật khẩu:</label>
                                @Html.Password("MatKhau", "", new { @class = "form-control" })
                                <span class="text-danger">@ViewData["Err2"]</span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">ĐĂNG NHẬP</button>
                            </div>
                        }
                    </div>
                    <div class="card-footer text-center py-3">
                        <div class="small">
                            <a href="@Url.Action("DangKy", "User")" style="text-decoration:none;">Chưa có tài khoản? Đăng ký ngay!</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>