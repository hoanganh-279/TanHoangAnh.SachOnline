<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - SachOnline</title>

    <!-- CSS -->
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <!-- CSS hiệu ứng ảnh chuyển từ Layout cũ sang -->
    <style type="text/css">
        .imgbook {
            transition: all 1s ease-in;
            width: 100%;
            height: 300px;
            object-fit: cover;
        }

            .imgbook:hover {
                transform: scale(0.9);
                cursor: pointer;
            }

        .imgsachbannhieu {
            width: 100px;
        }
    </style>
</head>
<body>
    <!-- Navbar (Sau này Lab yêu cầu tách thành NavbarPartial) -->
    @RenderSection("NavPartial", required: false)



    <div class="container body-content" style="margin-top: 20px;">
        <div style="margin-bottom: 25px;">
            @RenderSection("SliderPartial", required: false)
        </div>

        <div class="row">
            <!-- CỘT TRÁI (3 Phần): Chứa danh mục chủ đề, NXB, Sách bán nhiều -->
            <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12" style="margin-top: 25px;">
                @Html.Action("ChuDePartial", "SachOnline")

                @RenderSection("NhaXuatBanPartial", required: false)
            </div>

            <!-- CỘT PHẢI (9 Phần): Chứa nội dung chính (Sách Mới) -->
            <div class="col-lg-9 col-md-9 col-sm-9 col-xs-12">
                @RenderBody()

                @RenderSection("SachBanNhieuPartial", required: false)
            </div>
        </div>

        <hr />
        <footer>
            @RenderSection("FooterPartial", required: false)
        </footer>
    </div>

    <!-- Scripts: Bắt buộc jQuery nằm trên Bootstrap -->
    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>