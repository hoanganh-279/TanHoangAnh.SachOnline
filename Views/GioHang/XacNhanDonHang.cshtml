@{
    ViewBag.Title = "XacNhanDonHang";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

@section NavPartial {
    @Html.Action("NavPartial", "SachOnline")
}
@section FooterPartial {
    @Html.Action("FooterPartial", "SachOnline")
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="#198754" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                        </svg>
                    </div>

                    <h2 class="fw-bold text-success mb-3">ĐẶT HÀNG THÀNH CÔNG!</h2>

                    <h5 class="text-muted mb-4" style="line-height: 1.6;">
                        Cảm ơn quý khách đã tin tưởng và mua sắm tại SachOnline.<br />
                        Đơn hàng của quý khách đã được hệ thống ghi nhận. Chúng tôi sẽ liên hệ với quý khách trong thời gian sớm nhất để xác nhận và giao hàng đúng hẹn.
                    </h5>

                    <div class="mt-4">
                        @Html.ActionLink("TIẾP TỤC MUA SẮM", "Index", "SachOnline", null, new { @class = "btn btn-outline-success btn-lg px-4 me-2 rounded-pill fw-bold" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>