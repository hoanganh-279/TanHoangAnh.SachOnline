@using TanHoangAnh.SachOnline.Models
@model List<TanHoangAnh.SachOnline.Models.GioHang>
@{
    ViewBag.Title = "ĐƠN ĐẶT HÀNG";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

@section NavPartial {
    @Html.Action("NavPartial", "SachOnline")
}
@section FooterPartial {
    @Html.Action("FooterPartial", "SachOnline")
}

<div class="container mt-4 mb-5">
    <h2 class="text-center text-uppercase fw-bold text-primary mb-4">Xác Nhận & Đặt Hàng</h2>

    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white fw-bold">
                    TÓM TẮT ĐƠN HÀNG
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle text-center mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Ảnh Bìa</th>
                                    <th>Tên Sách</th>
                                    <th>Số Lượng</th>
                                    <th>Đơn Giá</th>
                                    <th>Thành Tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <img src="~/Images/@item.sAnhBia" class="img-thumbnail" style="width: 60px;" />
                                        </td>
                                        <td class="text-start">@item.sTenSach</td>

                                        @using (Html.BeginForm("CapnhatGiohang", "GioHang", new { iMaSach = item.iMaSach }))
                                        {
                                            <td>@item.iSoLuong</td>
                                            <td>@string.Format("{0:#,##0}", item.dDonGia) đ</td>
                                            <td class="text-danger fw-bold">@string.Format("{0:#,##0}", item.dThanhTien) đ</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light text-end">
                    <p class="mb-1">Tổng số lượng sách: <strong>@string.Format("{0:#,##0}", ViewBag.TongSoLuong)</strong></p>
                    <h5 class="mb-0">Tổng tiền thanh toán: <span class="text-danger fw-bold">@string.Format("{0:#,##0}", ViewBag.TongTien) VNĐ</span></h5>
                </div>
            </div>
            <div class="mt-3">
                @Html.ActionLink("← Trở về giỏ hàng", "GioHang", "GioHang", null, new { @class = "text-decoration-none" })
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-primary">
                <div class="card-header bg-primary text-white fw-bold">
                    THÔNG TIN GIAO HÀNG
                </div>
                <div class="card-body">
                    @{
                        KHACHHANG kh = (KHACHHANG)Session["TaiKhoan"];
                    }
                    @using (Html.BeginForm())
                    {
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="mb-3">
                            <label class="form-label text-muted">Họ tên khách hàng</label>
                            <input type="text" class="form-control fw-bold bg-light" value="@kh.HoTen" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted">Địa chỉ nhận hàng</label>
                            <textarea class="form-control fw-bold bg-light" rows="2" readonly>@kh.DiaChi</textarea>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted">Điện thoại</label>
                                <input type="text" class="form-control fw-bold bg-light" value="@kh.DienThoai" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Ngày đặt</label>
                                <input type="text" class="form-control fw-bold bg-light" value="@DateTime.Now.ToShortDateString()" readonly />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Ngày giao hàng dự kiến <span class="text-danger">*</span></label>
                            <input type="date" name="NgayGiao" class="form-control border-primary" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                            XÁC NHẬN ĐẶT HÀNG
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>