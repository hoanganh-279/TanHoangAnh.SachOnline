@{
    Layout = null;
    Response.ContentType = "text/html; charset=utf-8";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - SachOnline Admin</title>
    <!-- Preconnect để tải font nhanh hơn -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI',
                         Roboto, 'Helvetica Neue', Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eaf3ff;
            position: relative;
            overflow: hidden;
        }

        /* Decorative background shapes */
        .bg-shape {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }
        .bg-shape-1 {
            width: 520px; height: 520px;
            background: radial-gradient(circle at center, rgba(59,130,246,0.18), transparent 70%);
            top: -160px; left: -160px;
            animation: drift 10s ease-in-out infinite alternate;
        }
        .bg-shape-2 {
            width: 400px; height: 400px;
            background: radial-gradient(circle at center, rgba(99,204,255,0.15), transparent 70%);
            bottom: -120px; right: -120px;
            animation: drift 12s ease-in-out infinite alternate-reverse;
        }
        .bg-shape-3 {
            width: 220px; height: 220px;
            background: radial-gradient(circle at center, rgba(59,130,246,0.10), transparent 70%);
            top: 40%; left: 60%;
        }
        @@keyframes drift {
            from { transform: translate(0, 0) scale(1); }
            to   { transform: translate(24px, 18px) scale(1.07); }
        }

        /* Wrapper */
        .login-wrapper {
            width: 100%;
            max-width: 440px;
            padding: 16px;
            position: relative;
            z-index: 10;
        }

        /* Card */
        .login-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 48px 44px 40px;
            box-shadow: 0 8px 40px rgba(59,130,246,0.14),
                        0 2px 8px rgba(0,0,0,0.06);
            border: 1px solid rgba(59,130,246,0.10);
            animation: slideUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Logo */
        .login-logo {
            text-align: center;
            margin-bottom: 36px;
        }
        .logo-icon {
            width: 72px; height: 72px;
            background: linear-gradient(135deg, #2563eb, #38bdf8);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 18px;
            box-shadow: 0 8px 24px rgba(37,99,235,0.30);
        }
        .logo-icon i {
            font-size: 32px;
            color: #fff;
        }
        .login-logo h1 {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 23px;
            font-weight: 700;
            color: #1e3a5f;
            letter-spacing: -0.3px;
        }
        .login-logo p {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 13.5px;
            color: #64748b;
            margin-top: 5px;
        }

        /* Error alert */
        .alert-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            border-radius: 10px;
            padding: 11px 14px;
            font-family: 'Inter', -apple-system, sans-serif;
            font-size: 13.5px;
            margin-bottom: 22px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Floating-label input group */
        .field-group {
            position: relative;
            margin-bottom: 20px;
        }
        .field-group input {
            width: 100%;
            background: #f8faff;
            border: 1.5px solid #dbeafe;
            border-radius: 12px;
            padding: 20px 16px 8px 46px;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 14.5px;
            color: #1e3a5f;
            outline: none;
            transition: border-color 0.22s, background 0.22s, box-shadow 0.22s;
        }
        .field-group input::placeholder { color: transparent; }
        .field-group input:focus {
            border-color: #2563eb;
            background: #eff6ff;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
        }
        .field-group label {
            position: absolute;
            left: 46px;
            top: 50%;
            transform: translateY(-50%);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 14px;
            color: #94a3b8;
            pointer-events: none;
            transition: all 0.2s ease;
        }
        .field-group input:focus ~ label,
        .field-group input:not(:placeholder-shown) ~ label,
        .field-group input:-webkit-autofill ~ label {
            top: 10px;
            transform: none;
            font-size: 11px;
            font-weight: 500;
            color: #2563eb;
        }
        /* Fix màu nền autofill của browser */
        .field-group input:-webkit-autofill,
        .field-group input:-webkit-autofill:hover,
        .field-group input:-webkit-autofill:focus {
            -webkit-box-shadow: 0 0 0px 1000px #eff6ff inset;
            -webkit-text-fill-color: #1e3a5f;
            border-color: #93c5fd;
            transition: background-color 5000s ease-in-out 0s;
        }
        .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #93c5fd;
            font-size: 18px;
            pointer-events: none;
            transition: color 0.22s;
        }
        .field-group:focus-within .field-icon {
            color: #2563eb;
        }

        /* Toggle password eye */
        .toggle-pw {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #93c5fd;
            font-size: 17px;
            cursor: pointer;
            background: none;
            border: none;
            padding: 0;
            transition: color 0.2s;
        }
        .toggle-pw:hover { color: #2563eb; }

        /* Options row */
        .login-opts {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 26px;
        }
        .remember-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 13px;
            color: #64748b;
            cursor: pointer;
            user-select: none;
        }
        .remember-label input[type="checkbox"] {
            width: 16px; height: 16px;
            accent-color: #2563eb;
            cursor: pointer;
        }
        .forgot-link {
            font-family: 'Inter', -apple-system, sans-serif;
            font-size: 13px;
            color: #2563eb;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }
        .forgot-link:hover { color: #1d4ed8; text-decoration: underline; }

        /* Submit button */
        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #2563eb 0%, #38bdf8 100%);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: 0.2px;
            box-shadow: 0 6px 20px rgba(37,99,235,0.30);
            transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(37,99,235,0.40);
        }
        .btn-login:active { transform: translateY(0); opacity: 0.92; }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 22px 0 0;
            color: #cbd5e1;
            font-family: 'Inter', sans-serif;
            font-size: 12px;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

        /* Back link */
        .back-link {
            text-align: center;
            margin-top: 18px;
        }
        .back-link a {
            font-family: 'Inter', -apple-system, sans-serif;
            font-size: 13px;
            color: #94a3b8;
            text-decoration: none;
            transition: color 0.2s;
        }
        .back-link a:hover { color: #2563eb; }
        .back-link a i { margin-right: 4px; }
    </style>
</head>
<body>
    <!-- Background decorative shapes -->
    <div class="bg-shape bg-shape-1"></div>
    <div class="bg-shape bg-shape-2"></div>
    <div class="bg-shape bg-shape-3"></div>

    <div class="login-wrapper">
        <div class="login-card">

            <!-- Logo -->
            <div class="login-logo">
                <div class="logo-icon">
                    <i class="bi bi-book-half"></i>
                </div>
                <h1>SachOnline Admin</h1>
                <p>Hệ thống quản trị sách trực tuyến</p>
            </div>

            <!-- Error message -->
            @if (ViewBag.ThongBao != null)
            {
                <div class="alert-error">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @ViewBag.ThongBao
                </div>
            }

            <!-- Login form -->
            <form action="@Url.Action("Login", "Home", new { area = "Admin" })" method="post" autocomplete="off">

                <!-- Username -->
                <div class="field-group">
                    <i class="bi bi-person field-icon"></i>
                    <input type="text" id="UserName" name="UserName" placeholder=" " required>
                    <label for="UserName">Tên đăng nhập</label>
                </div>

                <!-- Password -->
                <div class="field-group">
                    <i class="bi bi-lock field-icon"></i>
                    <input type="password" id="Password" name="Password" placeholder=" " required>
                    <label for="Password">Mật khẩu</label>
                    <button type="button" class="toggle-pw" onclick="togglePw()" title="Hiện/ẩn mật khẩu">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>

                <!-- Options -->
                <div class="login-opts">
                    <label class="remember-label">
                        <input type="checkbox" name="remember"> Ghi nhớ đăng nhập
                    </label>
                    <a href="#" class="forgot-link">Quên mật khẩu?</a>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i>&nbsp; Đăng nhập
                </button>
            </form>

            <div class="divider">hoặc</div>

            <div class="back-link">
                <a href="@Url.Action("Index", "Home", new { area = "" })">
                    <i class="bi bi-arrow-left"></i> Quay về trang chủ
                </a>
            </div>
        </div>
    </div>

    <script>
        function togglePw() {
            var pw = document.getElementById('Password');
            var icon = document.getElementById('eyeIcon');
            if (pw.type === 'password') {
                pw.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                pw.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
</body>
</html>