@model IEnumerable<TanHoangAnh.SachOnline.Models.DONDATHANG>
@{
    ViewBag.Title = "Quản lý Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 class="text-primary text-center">QUẢN LÝ ĐƠN ĐẶT HÀNG</h2>

<table class="table table-bordered table-hover table-striped" style="margin-top:20px;">
    <tr>
        <th>Mã Đơn</th>
        <th>Tên Khách Hàng</th>
        <th>Ngày Đặt</th>
        <th>Ngày Giao</th>
        <th>Trạng Thái</th>
        <th>Hành động</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>#@item.MaDonHang</td>
            <td>@(item.KHACHHANG != null ? item.KHACHHANG.HoTen : "Khách ẩn danh")</td>

            <td>@(item.NgayDat.HasValue ? item.NgayDat.Value.ToString("dd/MM/yyyy HH:mm") : "")</td>

            <td>@(item.NgayGiao.HasValue ? item.NgayGiao.Value.ToString("dd/MM/yyyy") : "Chưa xác định")</td>
            <td>
                @if (item.TinhTrangGiaoHang == 1)
                {
                    <span class="label label-success">Đã giao hàng</span>
                }
                else
                {
                    <span class="label label-warning">Chưa giao hàng</span>
                }
            </td>
            <td>
                <a href="@Url.Action("Details", "DonHang", new { id = item.MaDonHang })" class="btn btn-info btn-sm">Chi tiết</a>
                <a href="@Url.Action("Edit", "DonHang", new { id = item.MaDonHang })" class="btn btn-warning btn-sm">Cập nhật</a>
            </td>
        </tr>
    }
</table>