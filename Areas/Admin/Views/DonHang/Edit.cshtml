@model TanHoangAnh.SachOnline.Models.DONDATHANG

@{
    ViewBag.Title = "Cập nhật Đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid pt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "DonHang")">Quản lý đơn hàng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Cập nhật #@Model.MaDonHang</li>
        </ol>
    </nav>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center bg-primary text-white">
            <h5 class="m-0 font-weight-bold">
                <i class="bi bi-pencil-square"></i> CẬP NHẬT ĐƠN HÀNG #@Model.MaDonHang
            </h5>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Edit", "DonHang", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.MaDonHang)

                <div class="row justify-content-center">
                    <div class="col-md-8">

                        <div class="mb-4">
                            <label class="form-label fw-bold"><i class="bi bi-truck"></i> Tình trạng giao hàng</label>
                            <select name="TinhTrangGiaoHang" class="form-select form-select-lg">
                                <option value="0" @(Model.TinhTrangGiaoHang == 0 || Model.TinhTrangGiaoHang == null ? "selected" : "")>
                                    🕒 Chưa giao hàng
                                </option>
                                <option value="1" @(Model.TinhTrangGiaoHang == 1 ? "selected" : "")>
                                    ✅ Đã giao hàng thành công
                                </option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold"><i class="bi bi-calendar-event"></i> Ngày giao dự kiến/thực tế</label>
                            <input type="date" name="Ngaygiao" class="form-control form-control-lg"
                                   value="@(Model.NgayGiao.HasValue ? Model.NgayGiao.Value.ToString("yyyy-MM-dd") : "")" />
                            <small class="text-muted">Lưu ý: Kiểm tra kỹ ngày trước khi lưu.</small>
                        </div>

                        <hr />

                        <div class="d-flex gap-2 justify-content-end">
                            <a href="@Url.Action("Index", "DonHang")" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold">
                                <i class="bi bi-save"></i> Lưu thay đổi
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 12px;
        overflow: hidden;
    }

    .form-select-lg, .form-control-lg {
        font-size: 1rem;
        border-radius: 8px;
    }

    .btn {
        border-radius: 8px;
        transition: all 0.3s;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
</style>