<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewBag.Title - SachOnline Admin</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Custom CSS (bạn có thể tạo thêm Site.css cho các style bổ sung) -->
    <link href="~/Content/Site.css" rel="stylesheet" />

    <style>
        :root {
            --primary-color: #0d6efd;
        }
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }
        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            width: 260px;
            background-color: #ffffff;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.08);
            z-index: 1000;
            overflow-y: auto;
        }
        .main-content {
            margin-left: 260px;
            min-height: 100vh;
            padding: 20px;
        }
        .navbar-brand {
            font-weight: 600;
            color: #0d6efd !important;
        }
        .nav-link {
            color: #495057;
            padding: 12px 20px;
            border-radius: 8px;
            margin: 4px 12px;
        }
        .nav-link:hover,
        .nav-link.active {
            background-color: #f1f3f5;
            color: #0d6efd;
        }
        .card {
            border: none;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        }
        @@media (max-width: 992px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
            }
            .main-content {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="p-4 border-bottom">
            <a href="@Url.Action("Dashboard", "Home")" class="text-decoration-none">
                <h4 class="navbar-brand mb-0">
                    <i class="bi bi-book"></i> SachOnline
                </h4>
                <small class="text-muted d-block">Quản trị viên</small>
            </a>
        </div>

        <ul class="nav flex-column pt-3">
            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "Dashboard" ? "active" : "")"
                   href="@Url.Action("Dashboard","Home")">
                    <i class="bi bi-house-door me-2"></i> Home
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "Sach" ? "active" : "")"
                   href="@Url.Action("Index","Sach")">
                    <i class="bi bi-book-half me-2"></i> Quản lý Sách
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "ChuDe" ? "active" : "")"
                   href="@Url.Action("Index","ChuDe")">
                    <i class="bi bi-tags me-2"></i> Quản lý Chủ đề
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "NhaXuatBan" ? "active" : "")"
                   href="@Url.Action("Index","NhaXuatBan")">
                    <i class="bi bi-building me-2"></i> Quản lý Nhà xuất bản
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "KhachHang" ? "active" : "")"
                   href="@Url.Action("Index","KhachHang")">
                    <i class="bi bi-people me-2"></i> Quản lý Khách hàng
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewBag.ActiveMenu == "DonHang" ? "active" : "")"
                   href="@Url.Action("Index","DonHang")">
                    <i class="bi bi-receipt me-2"></i> Quản lý Đơn hàng
                </a>
            </li>
        </ul>

        <div class="position-absolute bottom-0 w-100 p-4 border-top">
            <a href="@Url.Action("Logout","Home")" class="btn btn-outline-danger w-100">
                <i class="bi bi-box-arrow-right"></i> Đăng xuất
            </a>
        </div>
    </div>

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top" style="margin-left: 260px; z-index: 1020;">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> Admin
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#">Hồ sơ</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="@Url.Action("Logout","Account")">Đăng xuất</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content pt-5 mt-4">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>