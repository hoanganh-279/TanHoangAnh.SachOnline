@model TanHoangAnh.SachOnline.Models.CHUDE
@{
    ViewBag.Title = "S?a Ch? Đ?";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap');

    .edit-page-wrapper {
        font-family: 'Be Vietnam Pro', sans-serif;
        min-height: 100vh;
        padding: 2rem 1.5rem;
        background: #f4f6fb;
    }

    .edit-card {
        max-width: 560px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 4px 32px rgba(99, 102, 241, 0.10), 0 1.5px 6px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .edit-card-header {
        background: linear-gradient(120deg, #6366f1 0%, #818cf8 100%);
        padding: 2rem 2.2rem 1.6rem;
        position: relative;
    }

    .edit-card-header::after {
        content: '';
        position: absolute;
        bottom: -18px;
        left: 0;
        right: 0;
        height: 36px;
        background: #ffffff;
        border-radius: 50% 50% 0 0 / 100% 100% 0 0;
    }

    .header-icon {
        width: 44px;
        height: 44px;
        background: rgba(255,255,255,0.18);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.9rem;
    }

    .header-icon svg {
        width: 22px;
        height: 22px;
        stroke: #fff;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .edit-card-header h4 {
        color: #fff;
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: 0.01em;
    }

    .edit-card-header p {
        color: rgba(255,255,255,0.78);
        font-size: 0.82rem;
        margin: 0.25rem 0 0;
        font-weight: 400;
    }

    .edit-card-body {
        padding: 2.2rem 2.2rem 1.8rem;
    }

    .field-group {
        margin-bottom: 1.5rem;
    }

    .field-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 600;
        color: #6366f1;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 0.5rem;
    }

    .field-input-wrap {
        position: relative;
    }

    .field-input-wrap svg {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        width: 17px;
        height: 17px;
        stroke: #a5b4fc;
        fill: none;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        pointer-events: none;
    }

    .field-input-wrap input.form-control {
        width: 100%;
        padding: 0.65rem 0.9rem 0.65rem 2.4rem;
        border: 1.5px solid #e0e7ff;
        border-radius: 11px;
        font-size: 0.95rem;
        font-family: 'Be Vietnam Pro', sans-serif;
        color: #1e1b4b;
        background: #f8f9ff;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        outline: none;
        box-sizing: border-box;
    }

    .field-input-wrap input.form-control:focus {
        border-color: #6366f1;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.13);
    }

    .text-danger {
        font-size: 0.78rem;
        color: #ef4444;
        margin-top: 0.3rem;
        display: block;
    }

    .divider {
        height: 1px;
        background: #ede9fe;
        margin: 0.5rem 0 1.6rem;
    }

    .action-row {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.62rem 1.6rem;
        background: linear-gradient(120deg, #6366f1 0%, #818cf8 100%);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        font-family: 'Be Vietnam Pro', sans-serif;
        cursor: pointer;
        transition: opacity 0.18s, box-shadow 0.18s, transform 0.15s;
        box-shadow: 0 3px 12px rgba(99,102,241,0.25);
        text-decoration: none;
    }

    .btn-save:hover {
        opacity: 0.93;
        box-shadow: 0 6px 20px rgba(99,102,241,0.32);
        transform: translateY(-1px);
        color: #fff;
    }

    .btn-save svg {
        width: 16px;
        height: 16px;
        stroke: #fff;
        fill: none;
        stroke-width: 2.2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.62rem 1.3rem;
        background: #f1f0fe;
        color: #6366f1;
        border: 1.5px solid #e0e7ff;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 500;
        font-family: 'Be Vietnam Pro', sans-serif;
        text-decoration: none;
        transition: background 0.18s, border-color 0.18s, transform 0.15s;
    }

    .btn-back:hover {
        background: #ede9fe;
        border-color: #c7d2fe;
        color: #4f46e5;
        transform: translateY(-1px);
    }

    .btn-back svg {
        width: 15px;
        height: 15px;
        stroke: #6366f1;
        fill: none;
        stroke-width: 2.2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }
</style>

<div class="edit-page-wrapper">
    <div class="edit-card">
        <div class="edit-card-header">
            <div class="header-icon">
                <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
            <h4>S?a Ch? Đ?</h4>
            <p>C?p nh?t tęn ch? đ? trong h? th?ng</p>
        </div>

        <div class="edit-card-body">
            @using (Html.BeginForm("Edit", "ChuDe", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                @Html.HiddenFor(model => model.MaCD)

                <div class="field-group">
                    <label class="field-label">Tęn Ch? Đ?</label>
                    <div class="field-input-wrap">
                        <svg viewBox="0 0 24 24"><path d="M4 6h16M4 12h8m-8 6h16"/></svg>
                        @Html.EditorFor(model => model.TenChuDe, new { htmlAttributes = new { @class = "form-control", @required = "required", @placeholder = "Nh?p tęn ch? đ?..." } })
                    </div>
                    @Html.ValidationMessageFor(model => model.TenChuDe, "", new { @class = "text-danger" })
                </div>

                <div class="divider"></div>

                <div class="action-row">
                    <button type="submit" class="btn-save">
                        <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Lýu thay đ?i
                    </button>
                    <a href="@Url.Action("Index", "ChuDe")" class="btn-back">
                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                        Quay l?i danh sách
                    </a>
                </div>
            }
        </div>
    </div>
</div>
