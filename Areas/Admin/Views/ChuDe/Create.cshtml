@model TanHoangAnh.SachOnline.Models.CHUDE
@{
    ViewBag.Title = "Thêm Chủ Đề Mới";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 py-3">
                    <h4 class="mb-0 fw-semibold text-dark">
                        <i class="bi bi-tag me-2 text-primary"></i>Thêm Chủ Đề Mới
                    </h4>
                </div>
                <div class="card-body">

                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    @using (Html.BeginForm("Create", "ChuDe", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label fw-medium">Tên Chủ Đề</label>
                            @Html.EditorFor(model => model.TenChuDe, new
                            {
                                htmlAttributes = new
                                {
                                    @class = "form-control form-control-lg",
                                    @placeholder = "Nhập tên chủ đề...",
                                    @required = "required",
                                    autofocus = "autofocus"
                                }
                            })
                            @Html.ValidationMessageFor(model => model.TenChuDe, "", new { @class = "text-danger small" })
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-plus-lg me-1"></i> Thêm mới
                            </button>
                            <a href="@Url.Action("Index", "ChuDe")" class="btn btn-light px-4">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
