@model TanHoangAnh.SachOnline.Models.KHACHHANG
@{
    ViewBag.Title = "Sửa Thông Tin Khách Hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap');

    .edit-page-wrapper {
        font-family: 'Be Vietnam Pro', sans-serif;
        min-height: 100vh;
        padding: 2rem 1.5rem;
        background: #fdf4ff;
    }

    .edit-card {
        max-width: 640px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 4px 32px rgba(168, 85, 247, 0.10), 0 1.5px 6px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .edit-card-header {
        background: linear-gradient(120deg, #7c3aed 0%, #a855f7 100%);
        padding: 2rem 2.2rem 1.8rem;
        position: relative;
    }

    .edit-card-header::after {
        content: '';
        position: absolute;
        bottom: -18px; left: 0; right: 0;
        height: 36px;
        background: #ffffff;
        border-radius: 50% 50% 0 0 / 100% 100% 0 0;
    }

    .header-icon {
        width: 44px; height: 44px;
        background: rgba(255,255,255,0.18);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 0.9rem;
    }

    .header-icon svg {
        width: 22px; height: 22px;
        stroke: #fff; fill: none;
        stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    }

    .edit-card-header h4 {
        color: #fff; font-size: 1.25rem;
        font-weight: 700; margin: 0;
    }

    .edit-card-header p {
        color: rgba(255,255,255,0.78);
        font-size: 0.82rem; margin: 0.25rem 0 0;
    }

    .edit-card-body {
        padding: 2.4rem 2.2rem 2rem;
    }

    .fields-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.1rem 1.3rem;
    }

    .field-full { grid-column: 1 / -1; }

    .field-group { display: flex; flex-direction: column; }

    .field-label {
        font-size: 0.75rem; font-weight: 600;
        color: #7c3aed; text-transform: uppercase;
        letter-spacing: 0.07em; margin-bottom: 0.45rem;
    }

    .field-input-wrap { position: relative; }

    .field-input-wrap svg {
        position: absolute; left: 13px; top: 50%;
        transform: translateY(-50%);
        width: 16px; height: 16px;
        stroke: #d8b4fe; fill: none;
        stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
        pointer-events: none;
    }

    .field-input-wrap input.form-control {
        width: 100%;
        padding: 0.65rem 0.9rem 0.65rem 2.35rem;
        border: 1.5px solid #ede9fe;
        border-radius: 11px;
        font-size: 0.93rem;
        font-family: 'Be Vietnam Pro', sans-serif;
        color: #3b0764;
        background: #faf5ff;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        outline: none;
        box-sizing: border-box;
    }

    .field-input-wrap input.form-control:focus {
        border-color: #a855f7;
        background: #fff;
        box-shadow: 0 0 0 3px rgba(168, 85, 247, 0.13);
    }

    .field-input-wrap input.form-control:disabled {
        background: #f3f4f6;
        color: #9ca3af;
        cursor: not-allowed;
        border-color: #e5e7eb;
    }

    .badge-disabled {
        display: inline-block;
        font-size: 0.68rem; font-weight: 600;
        background: #f3e8ff; color: #9333ea;
        border-radius: 6px; padding: 0.15rem 0.5rem;
        margin-left: 0.4rem; vertical-align: middle;
        letter-spacing: 0.04em;
    }

    .divider {
        height: 1px; background: #f3e8ff;
        margin: 1.5rem 0 1.6rem; grid-column: 1 / -1;
    }

    .action-row {
        display: flex; gap: 0.75rem; align-items: center;
        grid-column: 1 / -1;
    }

    .btn-save {
        display: inline-flex; align-items: center; gap: 0.45rem;
        padding: 0.62rem 1.6rem;
        background: linear-gradient(120deg, #7c3aed 0%, #a855f7 100%);
        color: #fff; border: none; border-radius: 10px;
        font-size: 0.9rem; font-weight: 600;
        font-family: 'Be Vietnam Pro', sans-serif;
        cursor: pointer;
        transition: opacity 0.18s, box-shadow 0.18s, transform 0.15s;
        box-shadow: 0 3px 12px rgba(168,85,247,0.28);
        text-decoration: none;
    }

    .btn-save:hover {
        opacity: 0.92; box-shadow: 0 6px 20px rgba(168,85,247,0.35);
        transform: translateY(-1px); color: #fff;
    }

    .btn-save svg {
        width: 16px; height: 16px; stroke: #fff; fill: none;
        stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;
    }

    .btn-back {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.62rem 1.3rem;
        background: #faf5ff; color: #7c3aed;
        border: 1.5px solid #ede9fe; border-radius: 10px;
        font-size: 0.88rem; font-weight: 500;
        font-family: 'Be Vietnam Pro', sans-serif;
        text-decoration: none;
        transition: background 0.18s, border-color 0.18s, transform 0.15s;
    }

    .btn-back:hover {
        background: #f3e8ff; border-color: #d8b4fe;
        color: #6d28d9; transform: translateY(-1px);
    }

    .btn-back svg {
        width: 15px; height: 15px; stroke: #7c3aed; fill: none;
        stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;
    }

    @@media (max-width: 520px) {
        .fields-grid { grid-template-columns: 1fr; }
        .field-full { grid-column: 1; }
        .action-row { grid-column: 1; }
    }
</style>

<div class="edit-page-wrapper">
    <div class="edit-card">
        <div class="edit-card-header">
            <div class="header-icon">
                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h4>Sửa Thông Tin Khách Hàng</h4>
            <p>Cập nhật hồ sơ và thông tin liên hệ khách hàng</p>
        </div>

        <div class="edit-card-body">
            @using (Html.BeginForm("Edit", "KhachHang", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.MaKH)
                @Html.HiddenFor(model => model.TaiKhoan)

                <div class="fields-grid">

                    <div class="field-group field-full">
                        <label class="field-label">
                            Tài khoản
                            <span class="badge-disabled">Không thể sửa</span>
                        </label>
                        <div class="field-input-wrap">
                            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <input type="text" class="form-control" value="@Model.TaiKhoan" disabled />
                        </div>
                    </div>

                    <div class="field-group field-full">
                        <label class="field-label">Họ tên</label>
                        <div class="field-input-wrap">
                            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            @Html.EditorFor(model => model.HoTen, new { htmlAttributes = new { @class = "form-control", @required = "required", @placeholder = "Nhập họ và tên..." } })
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Email</label>
                        <div class="field-input-wrap">
                            <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", @type = "email", @placeholder = "email@example.com" } })
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Mật khẩu mới</label>
                        <div class="field-input-wrap">
                            <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <input type="password" name="MatKhau" class="form-control" placeholder="Nhập mật khẩu mới" />
                        </div>
                    </div>

                    <div class="field-group field-full">
                        <label class="field-label">Địa chỉ</label>
                        <div class="field-input-wrap">
                            <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            @Html.EditorFor(model => model.DiaChi, new { htmlAttributes = new { @class = "form-control", @placeholder = "Nhập địa chỉ..." } })
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Điện thoại</label>
                        <div class="field-input-wrap">
                            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 5.61 5.61l1.71-1.71a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/></svg>
                            @Html.EditorFor(model => model.DienThoai, new { htmlAttributes = new { @class = "form-control", @placeholder = "Nhập số điện thoai..." } })
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Ngày sinh</label>
                        <div class="field-input-wrap">
                            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <input type="date" name="NgaySinh" class="form-control"
                                   value="@(Model.NgaySinh.HasValue ? Model.NgaySinh.Value.ToString("yyyy-MM-dd") : "")" />
                        </div>
                    </div>

                    <div class="divider"></div>

                    <div class="action-row">
                        <button type="submit" class="btn-save">
                            <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            Lưu thay đổi
                        </button>
                        <a href="@Url.Action("Index", "KhachHang")" class="btn-back">
                            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                            Quay l?i
                        </a>
                    </div>

                </div>
            }
        </div>
    </div>
</div>
